    "@typescript-eslint/typescript-estree": "^8.42.0",
    "chalk": "^5.6.2",
    "cspell": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^10.1.8",
