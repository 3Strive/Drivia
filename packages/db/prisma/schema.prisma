generator client {
  provider = "prisma-client-js"
  output   = "../src/generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  name        String?
  address     String?
  phoneNumber String  @unique
}