{
  "name": "@drivia/db",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "prisma generate && tsc && cp -r src/generator dist/generator",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@prisma/client": "^6.8.2",
    "@prisma/extension-accelerate": "^1.3.0"
  },
  "devDependencies": {
    "@drivia/eslint-config": "workspace:*",
    "@drivia/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "prisma": "^6.8.2",
    "typescript": "5.5.4"
  }
}
