{
  "name": "@drivia/db",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write '**/*.{ts,tsx,json,md}' '!**/*.{js,jsx,d.ts}'",
    "format-check": "prettier --check '**/*.{ts,tsx,json,md}' '!**/*.{js,jsx,d.ts}'",
    "spell-check": "cspell \"**/*.{ts,tsx,json,md}\"",
    "build": "tsc",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "seed": "prisma db seed",
    "studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@prisma/client": "^6.8.2",
    "@prisma/extension-accelerate": "^1.3.0",
    "next": "15.5.5",
    "vite": "^7.1.10"
  },
  "devDependencies": {
    "@drivia/eslint-config": "workspace:*",
    "@drivia/typescript-config": "workspace:*",
    "prisma": "^6.8.2",
    "typescript": "5.5.4"
  }
}
